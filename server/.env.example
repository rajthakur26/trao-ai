# ---- Server ----
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:3000

# ---- Database ----
# MongoDB connection string (local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/trao

# ---- Auth ----
# Use a long random string in production, e.g. `openssl rand -hex 32`
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- LLM (Groq) ----
# Get a free key at https://console.groq.com/keys
# If left blank, the server falls back to a deterministic mock generator
# so the app stays fully functional without a key.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Localisation ----
# Default currency for budgets & prices (ISO 4217). INR = Indian Rupee (₹).
DEFAULT_CURRENCY=INR
